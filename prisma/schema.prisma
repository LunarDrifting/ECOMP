generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TaskLevel {
  MILESTONE
  STEP
  SUBSTEP
}

enum TaskState {
  NOT_STARTED
  IN_PROGRESS
  BLOCKED
  PENDING_APPROVAL
  DONE
  NOT_REQUIRED
  CANCELLED
}

enum TaskVisibility {
  INTERNAL_ONLY
  CUSTOMER_VISIBLE
  CUSTOMER_ACTIONABLE
}

enum ApprovalPolicy {
  NONE
  SINGLE
  SEQUENTIAL
  PARALLEL
  QUORUM
}

enum ClockMode {
  ACTIVE
  WAITING_ON_CUSTOMER
  WAITING_ON_SUPPLIER
  WAITING_INTERNAL
}

enum DependencyType {
  FINISH_TO_START
  START_TO_START
}

model Tenant {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users     User[]
  roles     Role[]
  ecos      ECO[]
  templates Template[]
  tasks     Task[]
  ecoPlans  ECOPlan[]
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  tenantId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userRoles UserRole[]
}

model Role {
  id        String   @id @default(cuid())
  name      String
  tenantId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant     Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userRoles  UserRole[]
  ownedTasks Task[]

  @@unique([name, tenantId])
}

model UserRole {
  id        String   @id @default(cuid())
  userId    String
  roleId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
}

model ECO {
  id          String   @id @default(cuid())
  title       String
  description String?
  tenantId    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  auditEvents AuditEvent[]
  tasks       Task[]
  ecoPlan     ECOPlan?
}

model Template {
  id        String   @id @default(cuid())
  name      String
  tenantId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  versions TemplateVersion[]

  @@unique([name, tenantId])
}

model TemplateVersion {
  id          String   @id @default(cuid())
  templateId  String
  version     String
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())

  template Template @relation(fields: [templateId], references: [id], onDelete: Cascade)
  ecoPlans ECOPlan[]

  @@unique([templateId, version])
}

model AuditEvent {
  id         String   @id @default(cuid())
  ecoId      String
  eventType  String
  actorId    String?
  payload    Json
  createdAt  DateTime @default(now())

  eco ECO @relation(fields: [ecoId], references: [id], onDelete: Cascade)
}

model Task {
  id             String          @id @default(cuid())
  tenantId       String
  ecoId          String
  parentTaskId   String?
  taskLevel      TaskLevel
  name           String
  ownerRoleId    String
  state          TaskState
  visibility     TaskVisibility
  approvalPolicy ApprovalPolicy
  clockMode      ClockMode
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  eco    ECO    @relation(fields: [ecoId], references: [id], onDelete: Cascade)
  owner  Role   @relation(fields: [ownerRoleId], references: [id], onDelete: Restrict)

  parent       Task?        @relation("TaskHierarchy", fields: [parentTaskId], references: [id], onDelete: SetNull)
  children     Task[]       @relation("TaskHierarchy")
  dependenciesFrom Dependency[] @relation("DependencyFrom")
  dependenciesTo   Dependency[] @relation("DependencyTo")

  @@index([tenantId])
  @@index([ecoId])
  @@index([ownerRoleId])
  @@index([parentTaskId])
}

model Dependency {
  id         String         @id @default(cuid())
  fromTaskId String
  toTaskId   String
  type       DependencyType
  lagMinutes Int
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  fromTask Task @relation("DependencyFrom", fields: [fromTaskId], references: [id], onDelete: Cascade)
  toTask   Task @relation("DependencyTo", fields: [toTaskId], references: [id], onDelete: Cascade)

  @@index([fromTaskId])
  @@index([toTaskId])
}

model ECOPlan {
  id                String          @id @default(cuid())
  ecoId             String
  templateVersionId String
  tenantId          String
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  eco             ECO             @relation(fields: [ecoId], references: [id], onDelete: Cascade)
  templateVersion TemplateVersion @relation(fields: [templateVersionId], references: [id], onDelete: Restrict)
  tenant          Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([ecoId])
  @@index([tenantId])
  @@index([templateVersionId])
}
