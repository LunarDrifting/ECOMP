generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TaskLevel {
  MILESTONE
  STEP
  SUBSTEP
}

enum TaskState {
  NOT_STARTED
  IN_PROGRESS
  BLOCKED
  PENDING_APPROVAL
  DONE
  NOT_REQUIRED
  CANCELLED
}

enum TaskVisibility {
  INTERNAL_ONLY
  CUSTOMER_VISIBLE
  CUSTOMER_ACTIONABLE
}

enum ApprovalPolicy {
  NONE
  SINGLE
  SEQUENTIAL
  PARALLEL
  QUORUM
}

enum ClockMode {
  ACTIVE
  WAITING_ON_CUSTOMER
  WAITING_ON_SUPPLIER
  WAITING_INTERNAL
}

enum DependencyType {
  FINISH_TO_START
  START_TO_START
}

enum ApprovalDecision {
  APPROVED
  REJECTED
}

enum GateType {
  PRECONDITION
  POSTCONDITION
}

model Tenant {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users     User[]
  roles     Role[]
  ecos      ECO[]
  templates Template[]
  tasks     Task[]
  ecoPlans  ECOPlan[]
  approvals Approval[]
  gates     Gate[]
  templateTaskDefinitions TemplateTaskDefinition[]
  templateDependencyDefinitions TemplateDependencyDefinition[]
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  tenantId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userRoles UserRole[]
  approvals Approval[]
}

model Role {
  id        String   @id @default(cuid())
  name      String
  tenantId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant     Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userRoles  UserRole[]
  ownedTasks Task[]
  templateTaskDefinitions TemplateTaskDefinition[]

  @@unique([name, tenantId])
}

model UserRole {
  id        String   @id @default(cuid())
  userId    String
  roleId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
}

model ECO {
  id          String   @id @default(cuid())
  title       String
  description String?
  tenantId    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  auditEvents AuditEvent[]
  tasks       Task[]
  ecoPlan     ECOPlan?
}

model Template {
  id        String   @id @default(cuid())
  name      String
  tenantId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  versions TemplateVersion[]

  @@unique([name, tenantId])
}

model TemplateVersion {
  id          String   @id @default(cuid())
  templateId  String
  version     String
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())

  template Template @relation(fields: [templateId], references: [id], onDelete: Cascade)
  ecoPlans ECOPlan[]
  templateTaskDefinitions TemplateTaskDefinition[]
  templateDependencyDefinitions TemplateDependencyDefinition[]

  @@unique([templateId, version])
}

model AuditEvent {
  id         String   @id @default(cuid())
  ecoId      String
  eventType  String
  actorId    String?
  payload    Json
  createdAt  DateTime @default(now())

  eco ECO @relation(fields: [ecoId], references: [id], onDelete: Cascade)
}

model Task {
  id             String          @id @default(cuid())
  tenantId       String
  ecoId          String
  parentTaskId   String?
  taskLevel      TaskLevel
  name           String
  ownerRoleId    String
  state          TaskState
  visibility     TaskVisibility
  approvalPolicy ApprovalPolicy
  clockMode      ClockMode
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  eco    ECO    @relation(fields: [ecoId], references: [id], onDelete: Cascade)
  owner  Role   @relation(fields: [ownerRoleId], references: [id], onDelete: Restrict)

  parent       Task?        @relation("TaskHierarchy", fields: [parentTaskId], references: [id], onDelete: SetNull)
  children     Task[]       @relation("TaskHierarchy")
  dependenciesFrom Dependency[] @relation("DependencyFrom")
  dependenciesTo   Dependency[] @relation("DependencyTo")
  approvals        Approval[]
  gates            Gate[]

  @@index([tenantId])
  @@index([ecoId])
  @@index([ownerRoleId])
  @@index([parentTaskId])
}

model Dependency {
  id         String         @id @default(cuid())
  fromTaskId String
  toTaskId   String
  type       DependencyType
  lagMinutes Int
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  fromTask Task @relation("DependencyFrom", fields: [fromTaskId], references: [id], onDelete: Cascade)
  toTask   Task @relation("DependencyTo", fields: [toTaskId], references: [id], onDelete: Cascade)

  @@index([fromTaskId])
  @@index([toTaskId])
}

model ECOPlan {
  id                String          @id @default(cuid())
  ecoId             String
  templateVersionId String
  tenantId          String
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  eco             ECO             @relation(fields: [ecoId], references: [id], onDelete: Cascade)
  templateVersion TemplateVersion @relation(fields: [templateVersionId], references: [id], onDelete: Restrict)
  tenant          Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([ecoId])
  @@index([tenantId])
  @@index([templateVersionId])
}

model Approval {
  id        String           @id @default(cuid())
  taskId    String
  actorId   String
  tenantId  String
  decision  ApprovalDecision
  comment   String?
  createdAt DateTime         @default(now())

  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  actor  User   @relation(fields: [actorId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model Gate {
  id        String   @id @default(cuid())
  taskId    String
  tenantId  String
  type      GateType
  condition Json
  createdAt DateTime @default(now())

  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model TemplateTaskDefinition {
  id                 String   @id @default(cuid())
  templateVersionId  String
  tenantId           String
  parentDefinitionId String?
  name               String
  taskLevel          TaskLevel
  ownerRoleId        String
  visibility         TaskVisibility
  approvalPolicy     ApprovalPolicy
  clockMode          ClockMode
  createdAt          DateTime @default(now())

  templateVersion TemplateVersion @relation(fields: [templateVersionId], references: [id], onDelete: Cascade)
  tenant          Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  ownerRole       Role            @relation(fields: [ownerRoleId], references: [id], onDelete: Restrict)

  parentDefinition   TemplateTaskDefinition?  @relation("TemplateTaskDefinitionHierarchy", fields: [parentDefinitionId], references: [id], onDelete: SetNull)
  childDefinitions   TemplateTaskDefinition[] @relation("TemplateTaskDefinitionHierarchy")
  outgoingDependencies TemplateDependencyDefinition[] @relation("TemplateDependencyFrom")
  incomingDependencies TemplateDependencyDefinition[] @relation("TemplateDependencyTo")

  @@index([templateVersionId])
  @@index([tenantId])
  @@index([ownerRoleId])
  @@index([parentDefinitionId])
}

model TemplateDependencyDefinition {
  id                String         @id @default(cuid())
  templateVersionId String
  tenantId          String
  fromDefinitionId  String
  toDefinitionId    String
  type              DependencyType
  lagMinutes        Int
  createdAt         DateTime       @default(now())

  templateVersion TemplateVersion      @relation(fields: [templateVersionId], references: [id], onDelete: Cascade)
  tenant          Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  fromDefinition  TemplateTaskDefinition @relation("TemplateDependencyFrom", fields: [fromDefinitionId], references: [id], onDelete: Cascade)
  toDefinition    TemplateTaskDefinition @relation("TemplateDependencyTo", fields: [toDefinitionId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([fromDefinitionId])
  @@index([toDefinitionId])
}
